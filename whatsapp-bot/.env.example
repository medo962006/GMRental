# ============================================================
# Hostel WhatsApp Bot - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Supabase Configuration (REQUIRED)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bot Configuration
BOT_NAME=HostelManagerBot

# Optional: Custom message template (Arabic)
# Use {name} and {room_number} as placeholders
# REMINDER_TEMPLATE=عزيزي {name} (غرفة {room_number}),\n\nهذا تذكير ودي بأن دفعة الإيجار مستحقة. يرجى تسديد المبلغ في أقرب وقت ممكن.\n\nشكراً لتعاونكم،\nإدارة السكن

# Optional: Cron schedule (default: 12:00 PM Egypt Time daily)
# CRON_SCHEDULE=0 12 * * *
# CRON_TIMEZONE=Africa/Cairo

# Optional: WhatsApp Web Client options
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# PUPPETEER_SKIP_DOWNLOAD=true